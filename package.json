{
  "name": "cc-rich",
  "version": "1.0.0",
  "description": "Claude Code Web Proxy — 浏览器端双栏 IDE (Electron)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ccrich.app",
    "productName": "CC Rich",
    "files": [
      "electron/**/*",
      "server.py",
      "public/**/*",
      "scripts/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0"
  }
}
